#!/usr/bin/env python3
"""
SageSMP Build Script
Builds SageSMP modules to ELF binaries with customizable options.
"""

import os
import sys
import subprocess
import json
from pathlib import Path

SAGE_BIN = "deps/SageLang/core/sage"
CONFIG_FILE = ".smp_config"

DEFAULT_CONFIG = {
    "host": "127.0.0.1",
    "port": 42000,
    "max_nodes": 64,
    "mailbox_size": 1024,
    "relay_host": "0.0.0.0",
    "relay_port": 42000,
    "enable_rtos": True,
    "enable_crypto": True
}

def banner(title):
    print(f"\n=== {title} ===")

def load_config():
    """Load user config from .smp_config file"""
    config = DEFAULT_CONFIG.copy()
    if Path(CONFIG_FILE).exists():
        with open(CONFIG_FILE) as f:
            user_config = json.load(f)
            config.update(user_config)
    return config

def save_config(config):
    """Save config to .smp_config file"""
    with open(CONFIG_FILE, "w") as f:
        json.dump(config, f, indent=2)

def run_cmd(cmd, cwd=None, shell=False, capture=True):
    result = subprocess.run(cmd, cwd=cwd, capture_output=capture, text=True, shell=shell)
    return result

def build_smp(target=None, all_targets=False, relay=False, client=False, demo=False, secure=False, orangepi=False, rpi2=False, rpi4=False):
    """Build SageSMP targets with customization"""
    if not Path(SAGE_BIN).exists():
        print("Error: Sage compiler not found. Run 'make -C deps/SageLang/core' first")
        return False
    
    os.makedirs("bin", exist_ok=True)
    
    targets = []
    
    if all_targets or demo:
        targets.append(("src/sage/demo/demo", "bin/demo_smp"))
    
    if all_targets or relay:
        targets.append(("src/sage/server/relay", "bin/relay"))
    
    if all_targets or orangepi:
        targets.append(("src/sage/server/orangepi_relay", "bin/orangepi_relay"))
    
    if all_targets or rpi2:
        targets.append(("src/sage/client/rpi2_client", "bin/rpi2_client"))
    
    if all_targets or rpi4:
        targets.append(("src/sage/client/rpi4_client", "bin/rpi4_client"))
    
    if all_targets or client:
        targets.append(("src/sage/client/client_shell", "bin/client_shell"))
    
    if all_targets or secure:
        targets.append(("src/sage/crypto/secure_msg", "bin/secure_msg"))
    
    if target:
        targets.append((target, f"bin/{Path(target).stem}"))
    
    if not targets:
        print("Usage: ./sagemake [target] [options]")
        print("\nTargets (specify .sage file without extension):")
        print("  src/sage/demo/demo         - Basic demo")
        print("  src/sage/server/relay      - OTP-encrypted relay server")
        print("  src/sage/server/orangepi_relay - OrangePi cluster relay server")
        print("  src/sage/client/client_shell - OTP-encrypted client shell")
        print("  src/sage/client/rpi2_client - RPi2 cluster client")
        print("  src/sage/client/rpi4_client - RPi4 cluster client")
        print("  src/sage/crypto/secure_msg - Secure message API demo")
        print("\nOptions:")
        print("  --all     Build all targets")
        print("  --demo    Build demo binary")
        print("  --relay   Build relay server (OTP-enabled)")
        print("  --orangepi Build OrangePi relay server")
        print("  --rpi2    Build RPi2 client")
        print("  --rpi4    Build RPi4 client")
        print("  --client  Build client shell (OTP-enabled)")
        print("  --secure  Build secure message API demo")
        print("  --init-config Initialize .smp_config file")
        print("  --test    Run test suite")
        return True
    
    successes = 0
    for src, out in targets:
        banner(f"Building {src}.sage")
        res = run_cmd([SAGE_BIN, "--compile", f"{src}.sage", "-o", out])
        if res.returncode == 0:
            print(f"Built: {out}")
            successes += 1
        else:
            print(f"Failed to build {src}.sage")
            if res.stderr:
                print(res.stderr)
    
    return successes == len(targets)

def init_config():
    """Initialize config file"""
    config = load_config()
    save_config(config)
    print(f"Created {CONFIG_FILE}")
    print("Edit this file to customize your build settings:")
    print(json.dumps(config, indent=2))

def main():
    import argparse
    parser = argparse.ArgumentParser(description="SageSMP Build Script")
    parser.add_argument("target", nargs="?", help="Specific .sage file to build (without .sage extension)")
    parser.add_argument("--all", action="store_true", help="Build all targets")
    parser.add_argument("--demo", action="store_true", help="Build demo binary")
    parser.add_argument("--relay", action="store_true", help="Build relay server")
    parser.add_argument("--client", action="store_true", help="Build client shell")
    parser.add_argument("--secure", action="store_true", help="Build secure message demo")
    parser.add_argument("--orangepi", action="store_true", help="Build OrangePi relay server")
    parser.add_argument("--rpi2", action="store_true", help="Build RPi2 client")
    parser.add_argument("--rpi4", action="store_true", help="Build RPi4 client")
    parser.add_argument("--init-config", action="store_true", help="Initialize config file")
    parser.add_argument("--test", action="store_true", help="Run test suite")
    args = parser.parse_args()
    
    if args.init_config:
        init_config()
    elif args.test:
        banner("Testing SageSMP")
        res = run_cmd([SAGE_BIN, "src/sage/demo/example.sage"])
        print(res.stdout)
    else:
        build_smp(
            target=args.target,
            all_targets=args.all,
            relay=args.relay,
            orangepi=args.orangepi,
            rpi2=args.rpi2,
            rpi4=args.rpi4,
            client=args.client,
            demo=args.demo,
            secure=args.secure
        )

if __name__ == "__main__":
    main()