{
  "title": "SageSMP Per-Device Detail",
  "tags": [
    "sagesmp",
    "devices"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "title": "Orangepi \u2014 CPU Temp",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "bfq8ajo0pyjggb"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sagesmp_cpu_temp_celsius{device=\"orangepi\"}",
          "legendFormat": "orangepi",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Orangepi \u2014 CPU Load",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "bfq8ajo0pyjggb"
      },
